{% extends 'layout/base.html.twig' %}
{% block title %}Ministérios{% endblock %}
{% block body %}
<div class="page-head">
  <h4 class="page-title"><span class="ico"><i class="bi bi-collection"></i></span> Ministérios</h4>
  <a href="{{ path('ministry_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo ministério</a>
</div>

<div class="row g-3">
{% for m in ministries %}
  <div class="col-md-6 col-xl-4">
    <div class="card p-3 h-100 {{ not m.active ? 'opacity-50' : '' }}">
      <div class="d-flex justify-content-between align-items-start">
        <h6 class="mb-1">{{ m.name }}</h6>
        <span class="badge bg-{{ m.active ? 'success' : 'secondary' }}">{{ m.active ? 'ativo' : 'inativo' }}</span>
      </div>
      {% if m.description %}<small class="text-muted d-block mb-2">{{ m.description }}</small>{% endif %}
      {% if m.leader %}<small><i class="bi bi-person-fill text-primary"></i> {{ m.leader }}</small>{% endif %}
      <div class="mt-2 small text-muted"><i class="bi bi-people"></i> {{ m.members|length }} membro(s)</div>
      <div class="mt-3 d-flex gap-2">
        <a href="{{ path('ministry_edit', {id:m.id}) }}" class="btn btn-sm btn-outline-primary">Editar</a>
        <form method="post" action="{{ path('ministry_delete', {id:m.id}) }}" onsubmit="return confirm('Excluir ministério?')">
          <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ m.id) }}">
          <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
        </form>
      </div>
    </div>
  </div>
{% else %}
  <div class="col-12"><div class="card p-4 text-center text-muted">Nenhum ministério cadastrado.</div></div>
{% endfor %}
</div>
{% endblock %}

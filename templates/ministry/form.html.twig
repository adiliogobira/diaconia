{% extends 'layout/base.html.twig' %}
{% block title %}{{ ministry ? 'Editar ' ~ ministry.name : 'Novo ministério' }}{% endblock %}
{% block body %}
<h4 class="mb-3">{{ ministry ? 'Editar: ' ~ ministry.name : 'Novo ministério' }}</h4>
<div class="card p-4" style="max-width:600px">
  {{ form_start(form) }}
  <div class="row g-3">
    <div class="col-12">{{ form_row(form.name) }}</div>
    <div class="col-12">{{ form_row(form.description) }}</div>
    <div class="col-md-8">{{ form_row(form.leader) }}</div>
    <div class="col-md-4 d-flex align-items-end">{{ form_row(form.active) }}</div>
  </div>
  <div class="mt-4">
    <button class="btn btn-primary">Salvar</button>
    <a href="{{ path('ministry_index') }}" class="btn btn-outline-secondary">Cancelar</a>
  </div>
  {{ form_end(form) }}
</div>
{% endblock %}

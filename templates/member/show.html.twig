{% extends 'layout/base.html.twig' %}
{% block title %}{{ member.fullName }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0">{{ member.fullName }}</h4>
  <div>
    <a href="{{ path('member_edit', {id:member.id}) }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil"></i> Editar</a>
    <form method="post" action="{{ path('member_delete', {id:member.id}) }}" class="d-inline" onsubmit="return confirm('Remover este membro?')">
      <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ member.id) }}">
      <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
    </form>
  </div>
</div>
<div class="row g-3">
  <div class="col-lg-8"><div class="card p-4">
    <dl class="row mb-0">
      <dt class="col-sm-3">Situação</dt><dd class="col-sm-9"><span class="badge bg-{{ member.status=='ativo'?'success':'secondary' }}">{{ member.status }}</span></dd>
      <dt class="col-sm-3">Função</dt><dd class="col-sm-9 text-capitalize">{{ member.churchRole }}</dd>
      <dt class="col-sm-3">Ministério</dt><dd class="col-sm-9">{{ member.ministries is not empty ? member.ministries|join(', ') : '—' }}</dd>
      <dt class="col-sm-3">Estado civil</dt><dd class="col-sm-9 text-capitalize">{{ member.maritalStatus ?? '—' }}</dd>
      <dt class="col-sm-3">Nascimento</dt><dd class="col-sm-9">{{ member.birthDate ? member.birthDate|date('d/m/Y') ~ ' (' ~ member.age ~ ' anos)' : '—' }}</dd>
      <dt class="col-sm-3">Batismo</dt><dd class="col-sm-9">{{ member.baptismDate ? member.baptismDate|date('d/m/Y') : '—' }}</dd>
      <dt class="col-sm-3">Telefone</dt><dd class="col-sm-9">{{ member.phone ?? '—' }}</dd>
      <dt class="col-sm-3">E-mail</dt><dd class="col-sm-9">{{ member.email ?? '—' }}</dd>
      <dt class="col-sm-3">Endereço</dt><dd class="col-sm-9">{{ member.address ?? '—' }}</dd>
    </dl>
  </div></div>
  <div class="col-lg-4"><div class="card p-4 text-center">
    {% if member.photoPath %}<img src="{{ asset(member.photoPath) }}" class="rounded-circle mb-2" width="120" height="120" style="object-fit:cover">
    {% else %}<i class="bi bi-person-circle display-1 text-secondary"></i>{% endif %}
    <p class="text-muted small mt-2">Cadastrado em {{ member.createdAt|date('d/m/Y') }}</p>
  </div></div>
</div>
{% endblock %}

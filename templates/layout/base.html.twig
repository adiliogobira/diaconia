<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title>{% block title %}{{ app_name }}{% endblock %}</title>

    {# ---- PWA ---- #}
    <link rel="manifest" href="{{ asset('manifest.webmanifest') }}">
    <meta name="theme-color" content="#4f46e5">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Diaconia">
    <link rel="apple-touch-icon" href="{{ asset('assets/icons/apple-touch-icon.png') }}">
    <link rel="icon" href="{{ asset('assets/icons/favicon-64.png') }}">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="{{ asset('assets/css/app.css') }}" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
</head>
<body>
{% if app.user %}
{% set route = app.request.attributes.get('_route') %}
<div class="app-shell">

    {# ============ SIDEBAR (desktop) ============ #}
    <aside class="sidebar d-none d-lg-flex">
        <div class="sidebar-brand">
            <i class="bi bi-buildings"></i>
            <span class="text-truncate">{{ app.user.church }}</span>
        </div>
        <nav class="sidebar-nav">
            {{ include('layout/_nav_links.html.twig', {route: route, style: 'sidebar'}) }}
        </nav>
        <div class="sidebar-footer">
            <div class="small text-truncate">{{ app.user.fullName }}</div>
            <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-light w-100 mt-2"><i class="bi bi-box-arrow-right"></i> Sair</a>
        </div>
    </aside>

    {# ============ CONTEÚDO ============ #}
    <main class="content">
        {# Top app bar (mobile) #}
        <header class="appbar d-lg-none">
            <div class="d-flex align-items-center gap-2 text-truncate">
                <i class="bi bi-buildings"></i>
                <strong class="text-truncate">{{ app.user.church }}</strong>
            </div>
            <button class="btn btn-sm btn-light" type="button" data-bs-toggle="offcanvas" data-bs-target="#menu">
                <i class="bi bi-list"></i>
            </button>
        </header>

        <div class="app-content container-fluid">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    {% set cls = label in ['success','danger','warning','info'] ? label : (label == 'error' ? 'danger' : 'info') %}
                    <div class="alert alert-{{ cls }} alert-dismissible fade show">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </div>
    </main>

    {# ============ BOTTOM NAV (mobile) ============ #}
    <nav class="bottom-nav d-lg-none">
        <a class="bn-item {{ route == 'app_dashboard' ? 'active' }}" href="{{ path('app_dashboard') }}">
            <i class="bi bi-speedometer2"></i><span>Painel</span>
        </a>
        {% if is_granted('MODULE_MEMBERS') %}
        <a class="bn-item {{ route starts with 'member' ? 'active' }}" href="{{ path('member_index') }}">
            <i class="bi bi-people"></i><span>Membros</span>
        </a>
        {% endif %}
        {% if is_granted('MODULE_DIACONIA') %}
        <a class="bn-item {{ route starts with 'diaconia' ? 'active' }}" href="{{ path('diaconia_index') }}">
            <i class="bi bi-hand-thumbs-up"></i><span>Diaconia</span>
        </a>
        {% endif %}
        {% if is_granted('MODULE_TREASURY') %}
        <a class="bn-item {{ route starts with 'treasury' ? 'active' }}" href="{{ path('treasury_index') }}">
            <i class="bi bi-cash-coin"></i><span>Tesouraria</span>
        </a>
        {% endif %}
        <button class="bn-item" type="button" data-bs-toggle="offcanvas" data-bs-target="#menu">
            <i class="bi bi-grid"></i><span>Mais</span>
        </button>
    </nav>
</div>

{# ============ OFFCANVAS "MAIS" (menu completo, mobile) ============ #}
<div class="offcanvas offcanvas-end" tabindex="-1" id="menu">
    <div class="offcanvas-header sidebar-brand text-white">
        <div class="d-flex align-items-center gap-2 text-truncate">
            <i class="bi bi-buildings"></i><span class="text-truncate">{{ app.user.church }}</span>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column">
        <nav class="sidebar-nav flex-grow-1">
            {{ include('layout/_nav_links.html.twig', {route: route, style: 'offcanvas'}) }}
        </nav>
        <div class="pt-3 border-top">
            <div class="small text-muted mb-2"><i class="bi bi-person-circle"></i> {{ app.user.fullName }}</div>
            <button id="pwa-install" class="btn btn-sm btn-outline-primary w-100 mb-2 d-none"><i class="bi bi-download"></i> Instalar aplicativo</button>
            <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger w-100"><i class="bi bi-box-arrow-right"></i> Sair</a>
        </div>
    </div>
</div>
{% else %}
    {% block auth %}{% endblock %}
{% endif %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  // Registro do service worker (PWA)
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js').catch(() => {}));
  }
  // Botão "Instalar aplicativo"
  let deferredPrompt;
  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
    const btn = document.getElementById('pwa-install');
    if (btn) {
      btn.classList.remove('d-none');
      btn.addEventListener('click', async () => {
        btn.classList.add('d-none');
        deferredPrompt.prompt();
        await deferredPrompt.userChoice;
        deferredPrompt = null;
      });
    }
  });
</script>
{% block javascripts %}{% endblock %}
</body>
</html>

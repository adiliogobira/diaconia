{% extends 'layout/base.html.twig' %}
{% block title %}Entrar — {{ app_name }}{% endblock %}
{% block auth %}
<div style="min-height:100vh;padding:1.5rem;display:grid;place-items:center;
     background:radial-gradient(1000px 500px at 100% 0%, rgba(139,92,246,.35), transparent 55%),
                radial-gradient(900px 500px at 0% 100%, rgba(99,102,241,.35), transparent 55%),
                linear-gradient(135deg,#4c1d95,#4338ca 60%,#6366f1);">
  <div style="width:100%;max-width:410px">
    <div class="text-center mb-4 text-white">
      <div style="width:72px;height:72px;border-radius:20px;display:grid;place-items:center;margin:0 auto 1rem;
           background:rgba(255,255,255,.16);backdrop-filter:blur(8px);box-shadow:0 20px 40px -16px rgba(0,0,0,.4)">
        <i class="bi bi-buildings" style="font-size:2rem"></i>
      </div>
      <h3 class="fw-bold mb-1">{{ app_name }}</h3>
      <p class="mb-0" style="opacity:.85">Gestão de igrejas · acesse sua conta</p>
    </div>

    <div class="card p-4 p-sm-4" style="box-shadow:0 30px 60px -20px rgba(0,0,0,.45)">
      {% if error %}
        <div class="alert alert-danger py-2 small mb-3">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
      {% endif %}
      <form method="post">
        <div class="mb-3">
          <label class="form-label">E-mail</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
            <input type="email" name="email" value="{{ last_username }}" class="form-control" placeholder="voce@igreja.org" required autofocus>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">Senha</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock"></i></span>
            <input type="password" name="password" class="form-control" placeholder="••••••••" required>
          </div>
        </div>
        <div class="form-check mb-3">
          <input class="form-check-input" type="checkbox" name="_remember_me" id="rm" checked>
          <label class="form-check-label small" for="rm">Manter-me conectado</label>
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button class="btn btn-primary w-100 py-2"><i class="bi bi-box-arrow-in-right"></i> Entrar</button>
      </form>
    </div>
    <p class="text-center mt-3 mb-0 small" style="color:rgba(255,255,255,.7)">© {{ "now"|date('Y') }} {{ app_name }}</p>
  </div>
</div>
{% endblock %}

{% extends 'layout/base.html.twig' %}
{% block title %}Gestão de Diáconos{% endblock %}
{% block body %}
<div class="page-head">
  <h4 class="page-title"><span class="ico"><i class="bi bi-person-badge"></i></span> Gestão de Diáconos</h4>
  <a href="{{ path('deacon_manage_new') }}" class="btn btn-primary"><i class="bi bi-person-plus"></i> Registrar diácono</a>
</div>

{% if leaders|length %}
<div class="alert alert-info py-2 mb-3">
  <i class="bi bi-shield-check"></i> <strong>Líderes do diaconato:</strong>
  {% for d in leaders %}{{ d.name }}{% if not loop.last %}, {% endif %}{% endfor %}
  — podem criar e gerir escalas sem ser administrador.
</div>
{% endif %}

<div class="card">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead class="table-light">
        <tr><th>Diácono</th><th>Situação</th><th>Ordenação</th><th>Acesso</th><th></th></tr>
      </thead>
      <tbody>
      {% for d in deacons %}
        <tr class="{{ not d.active ? 'text-muted' : '' }}">
          <td>
            <strong>{{ d.name }}</strong>
            {% if d.leader %}<span class="badge bg-primary ms-1">Líder</span>{% endif %}
          </td>
          <td><span class="badge bg-{{ d.active ? 'success' : 'secondary' }}">{{ d.active ? 'ativo' : 'inativo' }}</span></td>
          <td>{{ d.ordinationDate ? d.ordinationDate|date('d/m/Y') : '—' }}</td>
          <td>
            {% if d.leader %}
              <span class="badge bg-primary-subtle text-primary">Cria escalas</span>
            {% else %}
              <span class="badge bg-secondary-subtle text-secondary">Aceita vagas</span>
            {% endif %}
          </td>
          <td class="text-end">
            <a href="{{ path('deacon_manage_edit', {id:d.id}) }}" class="btn btn-sm btn-outline-primary">
              <i class="bi bi-pencil"></i> Editar
            </a>
          </td>
        </tr>
      {% else %}
        <tr><td colspan="5" class="text-center text-muted py-3">Nenhum diácono cadastrado.</td></tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
</div>

<div class="mt-3 p-3 bg-white rounded border">
  <h6><i class="bi bi-info-circle text-primary"></i> Como funciona o ACL de liderança</h6>
  <p class="mb-0 small text-muted">Um diácono marcado como <strong>Líder</strong> pode criar e gerir escalas (designar diáconos, montar vagas de serviço) sem precisar ter perfil de Administrador. Ao criar uma escala, <strong>todos os diáconos comuns</strong> (sem liderança) recebem notificação para se escalar. Os pastores visualizam e podem elaborar a Mesa da Santa Ceia.</p>
</div>
{% endblock %}

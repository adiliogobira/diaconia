{% extends 'layout/base.html.twig' %}
{% block title %}Editar — {{ deacon.name }}{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0">{{ deacon.name }}</h4>
  <a href="{{ path('deacon_manage_index') }}" class="btn btn-outline-secondary btn-sm">Voltar</a>
</div>

<div class="row g-3">
  <div class="col-lg-6">
    <div class="card p-4">
      <h6 class="mb-3">Configurações de acesso e situação</h6>
      {{ form_start(form) }}
        {{ form_row(form.leader) }}
        <div class="mb-3 small text-muted">O diácono líder pode criar escalas e gerir o diaconato. Ao criar uma escala, todos os diáconos comuns são notificados.</div>
        {{ form_row(form.active) }}
        {{ form_row(form.ordinationDate) }}
      <div class="mt-3">
        <button class="btn btn-primary">Salvar</button>
        <a href="{{ path('deacon_manage_index') }}" class="btn btn-outline-secondary">Cancelar</a>
      </div>
      {{ form_end(form) }}
    </div>
  </div>
  <div class="col-lg-6">
    <div class="card p-3">
      <h6 class="mb-3">Histórico de serviço</h6>
      <a href="{{ path('diaconia_history', {id:deacon.id}) }}" class="btn btn-outline-primary w-100">
        <i class="bi bi-clock-history"></i> Ver histórico de escalas
      </a>
    </div>
  </div>
</div>
{% endblock %}

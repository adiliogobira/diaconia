{% extends 'layout/base.html.twig' %}
{% block title %}Tesouraria{% endblock %}
{% block body %}
<div class="page-head">
  <h4 class="page-title"><span class="ico"><i class="bi bi-cash-coin"></i></span> Tesouraria — {{ year }}</h4>
  <a href="{{ path('treasury_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo lançamento</a>
</div>

<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3"><div class="card stat-card p-3"><small class="text-muted">Entradas</small><div class="h4 text-success mb-0">R$ {{ income|number_format(2,',','.') }}</div></div></div>
  <div class="col-6 col-lg-3"><div class="card stat-card p-3"><small class="text-muted">Saídas</small><div class="h4 text-danger mb-0">R$ {{ expense|number_format(2,',','.') }}</div></div></div>
  <div class="col-6 col-lg-3"><div class="card stat-card p-3"><small class="text-muted">Saldo</small><div class="h4 {{ balance>=0?'text-primary':'text-danger' }} mb-0">R$ {{ balance|number_format(2,',','.') }}</div></div></div>
  <div class="col-6 col-lg-3"><div class="card stat-card p-3"><small class="text-muted">Dízimos / Ofertas</small><div class="h6 mb-0">R$ {{ tithes|number_format(0,',','.') }} / {{ offerings|number_format(0,',','.') }}</div></div></div>
</div>

<div class="card p-3 mb-4"><h6>Fluxo de caixa mensal</h6><canvas id="tcf" height="90"></canvas></div>

<div class="card">
  <div class="table-responsive">
  <table class="table table-hover align-middle mb-0">
    <thead class="table-light"><tr><th>Data</th><th>Descrição</th><th>Natureza</th><th>Contribuinte</th><th class="text-end">Valor</th><th></th></tr></thead>
    <tbody>
    {% for t in transactions %}
      <tr>
        <td>{{ t.occurredAt|date('d/m/Y') }}</td>
        <td>{{ t.description ?? t.kind }}</td>
        <td class="text-capitalize">{{ t.kind }}</td>
        <td>{{ t.member ?? '—' }}</td>
        <td class="text-end {{ t.income?'text-success':'text-danger' }}">{{ t.income?'+':'−' }} R$ {{ t.amount|number_format(2,',','.') }}</td>
        <td class="text-end">
          <form method="post" action="{{ path('treasury_delete', {id:t.id}) }}" onsubmit="return confirm('Excluir?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ t.id) }}">
            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
          </form>
        </td>
      </tr>
    {% else %}<tr><td colspan="6" class="text-center text-muted py-4">Nenhum lançamento.</td></tr>{% endfor %}
    </tbody>
  </table>
  </div>
</div>

<script>
const cf = {{ cashFlow|json_encode|raw }};
new Chart(document.getElementById('tcf'), {
  type:'line',
  data:{ labels:['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'],
    datasets:[
      {label:'Entradas',data:Object.values(cf).map(x=>x.entrada),borderColor:'#22c55e',tension:.3},
      {label:'Saídas',data:Object.values(cf).map(x=>x.saida),borderColor:'#ef4444',tension:.3}
    ]},
  options:{plugins:{legend:{position:'bottom'}}}
});
</script>
{% endblock %}

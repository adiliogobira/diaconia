{% extends 'layout/base.html.twig' %}
{% block title %}Dados da igreja{% endblock %}
{% block body %}
<h4 class="mb-3">Dados da igreja</h4>
<div class="card p-4" style="max-width:640px">
  {{ form_start(form) }}
  <div class="row g-3">
    <div class="col-md-8">{{ form_row(form.name) }}</div>
    <div class="col-md-4">{{ form_row(form.cnpj) }}</div>
    <div class="col-md-6">{{ form_row(form.phone) }}</div>
    <div class="col-md-6">{{ form_row(form.email) }}</div>
    <div class="col-12">{{ form_row(form.address) }}</div>
  </div>
  <div class="mt-4"><button class="btn btn-primary">Salvar</button>
    <a href="{{ path('admin_index') }}" class="btn btn-outline-secondary">Cancelar</a></div>
  {{ form_end(form) }}
</div>
{% endblock %}

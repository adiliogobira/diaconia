{% extends 'layout/base.html.twig' %}
{% block title %}{{ is_new ? 'Novo usuário' : 'Editar usuário' }}{% endblock %}
{% block body %}
<h4 class="mb-3">{{ is_new ? 'Novo usuário' : 'Editar usuário' }}</h4>
<div class="card p-4" style="max-width:640px">
  {{ form_start(form) }}
  <div class="row g-3">
    <div class="col-md-6">{{ form_row(form.fullName) }}</div>
    <div class="col-md-6">{{ form_row(form.email) }}</div>
    <div class="col-md-6">{{ form_row(form.member) }}</div>
    <div class="col-md-6">{{ form_row(form.plainPassword) }}</div>
    <div class="col-12">{{ form_row(form.roles) }}</div>
    <div class="col-12">{{ form_row(form.active) }}</div>
  </div>
  <div class="mt-4"><button class="btn btn-primary">Salvar</button>
    <a href="{{ path('admin_index') }}" class="btn btn-outline-secondary">Cancelar</a></div>
  {{ form_end(form) }}
</div>
{% endblock %}

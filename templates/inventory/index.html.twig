{% extends 'layout/base.html.twig' %}
{% block title %}Estoque de doações{% endblock %}
{% block body %}
<div class="page-head">
  <h4 class="page-title"><span class="ico"><i class="bi bi-box-seam"></i></span> Estoque de doações</h4>
  <a href="{{ path('inventory_new') }}" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo item</a>
</div>

{% if lowCount > 0 %}
  <div class="alert alert-warning py-2"><i class="bi bi-exclamation-triangle"></i> {{ lowCount }} item(ns) com estoque baixo.</div>
{% endif %}

{% for cat, label in categories %}
  {% if grouped[cat] is defined %}
  <div class="card mb-3">
    <div class="card-header bg-white"><strong>{{ label }}</strong></div>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead class="table-light"><tr><th>Item</th><th class="text-end">Quantidade</th><th></th></tr></thead>
        <tbody>
        {% for i in grouped[cat] %}
          <tr class="{{ i.isLow ? 'table-warning' : '' }}">
            <td>{{ i.name }}{% if i.isLow %} <span class="badge bg-warning text-dark">baixo</span>{% endif %}</td>
            <td class="text-end fw-medium">{{ i.quantity|number_format(i.quantity == i.quantity|round ? 0 : 2, ',', '.') }} {{ i.unit }}</td>
            <td class="text-end"><a href="{{ path('inventory_show', {id:i.id}) }}" class="btn btn-sm btn-outline-primary">Movimentar</a></td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% endif %}
{% endfor %}

{% if grouped is empty %}
  <div class="card p-4 text-center text-muted">Nenhum item cadastrado. Comece adicionando as doações recebidas.</div>
{% endif %}
{% endblock %}

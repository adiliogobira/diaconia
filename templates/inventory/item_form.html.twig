{% extends 'layout/base.html.twig' %}
{% block title %}Novo item{% endblock %}
{% block body %}
<h4 class="mb-3">Novo item de estoque</h4>
<div class="card p-4" style="max-width:560px">
  {{ form_start(form) }}
  <div class="row g-3">
    <div class="col-12">{{ form_row(form.name) }}</div>
    <div class="col-md-6">{{ form_row(form.category) }}</div>
    <div class="col-md-3">{{ form_row(form.unit) }}</div>
    <div class="col-md-3">{{ form_row(form.minQuantity) }}</div>
  </div>
  <div class="mt-3"><button class="btn btn-primary">Cadastrar</button>
    <a href="{{ path('inventory_index') }}" class="btn btn-outline-secondary">Cancelar</a></div>
  {{ form_end(form) }}
  <small class="text-muted d-block mt-2">Sem valores monetários — apenas nome e quantidade.</small>
</div>
{% endblock %}

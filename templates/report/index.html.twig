{% extends 'layout/base.html.twig' %}
{% block title %}Relatórios{% endblock %}
{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0"><i class="bi bi-graph-up text-primary"></i> Relatórios — {{ year }}</h4>
</div>

<div class="row g-3 mb-3">
  <div class="col-6 col-lg-3"><div class="card stat-card p-3"><small class="text-muted">Membros</small><div class="h4 mb-0">{{ membersTotal }}</div></div></div>
  <div class="col-6 col-lg-3"><div class="card stat-card p-3"><small class="text-muted">Saldo do ano</small><div class="h4 {{ balance>=0?'text-primary':'text-danger' }} mb-0">R$ {{ balance|number_format(0,',','.') }}</div></div></div>
  <div class="col-6 col-lg-3"><div class="card stat-card p-3"><small class="text-muted">Escalas</small><div class="h4 mb-0">{{ schedulesCount }}</div></div></div>
  <div class="col-6 col-lg-3"><div class="card stat-card p-3"><small class="text-muted">Eventos</small><div class="h4 mb-0">{{ eventsCount }}</div></div></div>
</div>

<div class="row g-3">
  <div class="col-lg-5">
    <div class="card p-3 h-100">
      <h6 class="mb-3">Membros por situação</h6>
      <canvas id="statusChart" height="200"></canvas>
    </div>
  </div>
  <div class="col-lg-7">
    <div class="card p-3 h-100">
      <h6 class="mb-3">Fluxo de caixa mensal</h6>
      <canvas id="cashChart" height="180"></canvas>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="card p-3">
      <h6 class="mb-3">Serviço (Diaconia)</h6>
      <p class="mb-1"><span class="badge bg-success">{{ slotsFilled }}</span> vagas preenchidas</p>
      <p class="mb-0"><span class="badge bg-warning-subtle text-warning-emphasis">{{ slotsOpen }}</span> vagas abertas</p>
    </div>
  </div>
  <div class="col-lg-7">
    <div class="card p-3">
      <h6 class="mb-3">Contribuições do ano</h6>
      <div class="row text-center">
        <div class="col"><small class="text-muted d-block">Dízimos</small><strong>R$ {{ tithes|number_format(0,',','.') }}</strong></div>
        <div class="col"><small class="text-muted d-block">Ofertas</small><strong>R$ {{ offerings|number_format(0,',','.') }}</strong></div>
        <div class="col"><small class="text-muted d-block">Entradas</small><strong class="text-success">R$ {{ income|number_format(0,',','.') }}</strong></div>
        <div class="col"><small class="text-muted d-block">Saídas</small><strong class="text-danger">R$ {{ expense|number_format(0,',','.') }}</strong></div>
      </div>
    </div>
  </div>
</div>

<script>
const bs = {{ byStatus|json_encode|raw }};
new Chart(document.getElementById('statusChart'), {
  type:'doughnut',
  data:{ labels:['Ativos','Inativos','Disciplina','Transferidos'],
    datasets:[{data:[bs.ativo,bs.inativo,bs.disciplina,bs.transferido],
      backgroundColor:['#22c55e','#94a3b8','#f59e0b','#6366f1']}]},
  options:{plugins:{legend:{position:'bottom'}}}
});
const cf = {{ cashFlow|json_encode|raw }};
new Chart(document.getElementById('cashChart'), {
  type:'bar',
  data:{ labels:['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'],
    datasets:[
      {label:'Entradas',data:Object.values(cf).map(x=>x.entrada),backgroundColor:'#22c55e'},
      {label:'Saídas',data:Object.values(cf).map(x=>x.saida),backgroundColor:'#ef4444'}
    ]},
  options:{plugins:{legend:{position:'bottom'}},scales:{x:{stacked:false}}}
});
</script>
{% endblock %}

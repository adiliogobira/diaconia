{% extends 'layout/base.html.twig' %}
{% block title %}Novo agendamento{% endblock %}
{% block body %}
<h4 class="mb-3">Novo agendamento pastoral</h4>
<div class="card p-4" style="max-width:640px">
  {{ form_start(form) }}
  <div class="row g-3">
    <div class="col-md-6">{{ form_row(form.type) }}</div>
    <div class="col-md-6">{{ form_row(form.scheduledAt) }}</div>
    <div class="col-md-6">{{ form_row(form.member) }}</div>
    <div class="col-md-6">{{ form_row(form.pastor) }}</div>
    <div class="col-12">{{ form_row(form.subject) }}</div>
    <div class="col-12">{{ form_row(form.confidentialNotes) }}</div>
    <div class="col-md-6">{{ form_row(form.status) }}</div>
  </div>
  <div class="mt-4"><button class="btn btn-primary">Salvar</button>
    <a href="{{ path('pastoral_index') }}" class="btn btn-outline-secondary">Cancelar</a></div>
  {{ form_end(form) }}
</div>
{% endblock %}

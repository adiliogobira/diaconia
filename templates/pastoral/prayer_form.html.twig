{% extends 'layout/base.html.twig' %}
{% block title %}Pedido de oração{% endblock %}
{% block body %}
<h4 class="mb-3">Novo pedido de oração</h4>
<div class="card p-4" style="max-width:560px">
  {{ form_start(form) }}
  {{ form_row(form.requesterName) }}
  {{ form_row(form.request) }}
  {{ form_row(form.confidential) }}
  <div class="mt-3"><button class="btn btn-primary">Registrar</button>
    <a href="{{ path('pastoral_index') }}" class="btn btn-outline-secondary">Cancelar</a></div>
  {{ form_end(form) }}
</div>
{% endblock %}

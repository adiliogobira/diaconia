{% extends 'layout/base.html.twig' %}
{% block title %}Notificações{% endblock %}
{% block body %}
<div class="page-head">
  <h4 class="page-title"><span class="ico"><i class="bi bi-bell"></i></span> Notificações</h4>
  <form method="post" action="{{ path('notification_read_all') }}">
    <input type="hidden" name="_token" value="{{ csrf_token('read_all') }}">
    <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-check2-all"></i> Marcar todas como lidas</button>
  </form>
</div>

<div class="card">
  <div class="list-group list-group-flush">
    {% for n in notifications %}
      <a href="{{ path('notification_open', {id:n.id}) }}"
         class="list-group-item list-group-item-action d-flex gap-3 {{ n.read ? '' : 'bg-primary-subtle' }}">
        <i class="bi bi-{{ n.icon }} fs-5 text-primary"></i>
        <div class="flex-grow-1">
          <div class="d-flex justify-content-between">
            <strong>{{ n.title }}</strong>
            <small class="text-muted">{{ n.createdAt|date('d/m H:i') }}</small>
          </div>
          <div class="small text-muted">{{ n.message }}</div>
        </div>
        {% if not n.read %}<span class="badge bg-primary align-self-center">nova</span>{% endif %}
      </a>
    {% else %}
      <div class="list-group-item text-center text-muted py-4">Nenhuma notificação.</div>
    {% endfor %}
  </div>
</div>
{% endblock %}

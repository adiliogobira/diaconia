{% extends 'layout/base.html.twig' %}
{% block title %}{{ class.name }}{% endblock %}
{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
  <div>
    <h4 class="mb-0">{{ class.name }}</h4>
    <small class="text-muted">{{ class.ageGroup ?? 'Turma' }}{% if class.teacher %} · Prof. {{ class.teacher }}{% endif %}</small>
  </div>
  <div class="d-flex gap-2">
    <a href="{{ path('school_attendance', {id:class.id}) }}" class="btn btn-primary btn-sm"><i class="bi bi-check2-square"></i> Fazer chamada</a>
    <a href="{{ path('school_index') }}" class="btn btn-outline-secondary btn-sm">Voltar</a>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-7">
    <div class="card p-3">
      <h6 class="mb-3">Alunos ({{ class.students|length }})</h6>
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="table-light"><tr><th>Nome</th></tr></thead>
          <tbody>
          {% for s in class.students %}
            <tr><td>{{ s.fullName }}</td></tr>
          {% else %}<tr><td class="text-center text-muted py-3">Nenhum aluno na turma.</td></tr>{% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="card p-3">
      <h6 class="mb-3">Adicionar aluno</h6>
      <form method="post" action="{{ path('school_add_student', {id:class.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('student' ~ class.id) }}">
        <div class="mb-2"><input name="fullName" class="form-control" placeholder="Nome do aluno" required></div>
        <button class="btn btn-primary w-100"><i class="bi bi-plus-lg"></i> Adicionar</button>
      </form>
    </div>
  </div>
</div>
{% endblock %}
